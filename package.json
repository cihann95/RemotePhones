{
  "name": "phone-farm",
  "version": "2.0.0",
  "description": "Phone Farm - Professional Phone Management System by SERGIO",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "dependencies": {
    "@cryptlex/lexactivator": "^3.37.0",
    "electron-log": "^5.1.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "happy-dom": "^20.10.3",
    "jsdom": "^29.1.1",
    "vitest": "^1.6.1"
  },
  "author": "SERGIO",
  "license": "MIT",
  "build": {
    "appId": "com.sergio.phonefarm",
    "productName": "Phone Farm",
    "artifactName": "PhoneFarm-Setup-${version}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "tools",
        "to": "tools",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "src/main/Product.dat",
        "to": "Product.dat"
      },
      {
        "from": "dist/phone_farm_cli",
        "to": "phone_farm_cli"
      },
      {
        "from": "dist/phone_farm_cli.exe",
        "to": "phone_farm_cli.exe"
      }
    ],
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "cihann95",
        "repo": "RemotePhones"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/phoneFarm.ico",
      "signAndEditExecutable": true,
      "certificateFile": "${env.CSC_LINK}",
      "certificatePassword": "${env.CSC_KEY_PASSWORD}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Phone Farm",
      "installerIcon": "assets/phoneFarm.ico",
      "uninstallerIcon": "assets/phoneFarm.ico",
      "runAfterFinish": true,
      "script": "build/installer.nsh"
    }
  }
}
