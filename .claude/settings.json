{
  "permissions": {
    "allow": [
      "Bash(npm start)",
      "Bash(npm run build)",
      "Bash(npm install)",
      "Bash(npm test)",
      "Bash(npx electron-builder:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(dir:*)",
      "Bash(ls:*)",
      "Bash(node:*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "0"
  }
}