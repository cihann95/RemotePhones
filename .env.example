# =============================================================================
# RemotePhones - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your deployment.
#   cp .env.example .env
# =============================================================================

# API authentication key (required for protected endpoints)
API_SECRET_KEY=

# Rate limit per IP (default: 100)
RATE_LIMIT_PER_MINUTE=100

# Data directory for job_queue.db and logs (default: ./data)
DATA_DIR=./data

# Comma-separated allowed CORS origins (default: http://127.0.0.1:8000,http://localhost:8000)
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Path to YAML config file (default: config/phone_farm.yaml)
PHONE_FARM_CONFIG=config/phone_farm.yaml

# Path to ADB binary (default: adb — must be on PATH)
PHONE_FARM_ADB_PATH=adb

# Node environment (development/production)
NODE_ENV=production
